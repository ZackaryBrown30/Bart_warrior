  <body>
    <%- include('header'); -%>
    <div class="container">
      <div class="row">
        <!-- If the Api has no data within these parameters for north and or south, the user sees a message explaining There are no respective trains.  -->

        <% if (!North.root.station[0].etd) { %>
        <div class="col-md-5 m-1 rounded bg-warning text-primary">
          <h1 class="p-2">No Northbound Trains at this Time</h1>
        </div>
        <%}%> <% if (!South.root.station[0].etd) { %>
        <div class="col-md-5 m-1 rounded bg-primary text-light">
          <h1 class="p-2">No Southbound Trains at this Time</h1>
        </div>
        <%}%>

        <!-- If no times are listed, bart is not running at this station, display afterhours -->

        <% if (!South.root.station[0].etd && !North.root.station[0].etd) { %>
        <%-include('afterHours'); %> <%}%>

        <!-- Northbound Module  -->
        <% if (North.root.station[0].etd) { %> <%- include('north'); -%> <% }
        -%>

        <!-- SouthBound Module -->
        <% if (South.root.station[0].etd) { %> <%- include('south'); -%> <% }
        -%>
