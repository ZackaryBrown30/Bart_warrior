<div class="card">
  <button
    class="btn bg-warning rounded card-header collapsed"
    type="button"
    id="headingMap"
    data-toggle="collapse"
    data-target="#collapseMap"
    aria-expanded="true"
    aria-controls="collapseMap"
  >
    <h1>Service Map</h1>
  </button>

  <div
    id="collapseMap"
    class="show"
    aria-labelledby="headingMap"
    data-parent="#citySelector"
  >
    <div class="card-body p-0">
      <!-- Responsive map with SVG overlay for clickable stations -->
      <div style="position:relative;max-width:900px;margin:0 auto;">
        <img src="/static/map.png" alt="BART Service Map" style="width:100%;height:auto;display:block;" />

        <!-- SVG overlay uses viewBox coordinates (0..1000 x 0..500) - adjust circles as needed -->
        <svg viewBox="0 0 1000 500" preserveAspectRatio="xMidYMid meet" style="position:absolute;left:0;top:0;width:100%;height:100%;pointer-events:none;">
          <style>
            .hotspot { fill: rgba(255,255,255,0); stroke: rgba(255,255,255,0); }
            .hotspot-hover { fill: rgba(255,193,7,0.7); stroke: rgba(255,193,7,0.9); }
          </style>

          <!-- Example hotspots: adjust cx/cy to match your map -->
          <g id="hotspots" style="pointer-events:auto;">
            <a onclick="location.href='19th'">
              <circle class="hotspot" cx="330" cy="270" r="18" />
            </a>
            <a onclick="location.href='12th'">
              <circle class="hotspot" cx="300" cy="265" r="18" />
            </a>
            <a onclick="location.href='woak'">
              <circle class="hotspot" cx="200" cy="230" r="18" />
            </a>
            <a onclick="location.href='lake'">
              <circle class="hotspot" cx="360" cy="300" r="16" />
            </a>
            <a onclick="location.href='mcar'">
              <circle class="hotspot" cx="420" cy="210" r="16" />
            </a>
            <a onclick="location.href='cols'">
              <circle class="hotspot" cx="720" cy="320" r="18" />
            </a>
            <a onclick="location.href='rock'">
              <circle class="hotspot" cx="480" cy="180" r="16" />
            </a>
          </g>
        </svg>
      </div>
      <script>
        // Small enhancement: highlight hotspot on touch / mouseover
        (function(){
          const svg = document.querySelector('#collapseMap svg');
          if(!svg) return;
          svg.addEventListener('mouseover', (e)=>{
            if(e.target.tagName==='circle'){
              e.target.classList.add('hotspot-hover');
            }
          });
          svg.addEventListener('mouseout', (e)=>{
            if(e.target.tagName==='circle'){
              e.target.classList.remove('hotspot-hover');
            }
          });
          // Enable touch highlight
          svg.addEventListener('touchstart', (e)=>{
            const c = e.target;
            if(c.tagName==='circle') c.classList.add('hotspot-hover');
          });
          svg.addEventListener('touchend', (e)=>{
            const c = e.target;
            if(c.tagName==='circle') c.classList.remove('hotspot-hover');
          });
        })();
      </script>
    </div>
  </div>
</div>